  public static class Builder<T> {
      private HoodieReaderContext<T> readerContext;        // engine-specific (Spark InternalRow, Flink RowData)
      private HoodieStorage storage;                       // derived from metaClient + storageConf
      private String tablePath;                            // base path
      private String latestCommitTime;                     // query timestamp / end instant
      private HoodieSchema dataSchema;                     // full table schema
      private HoodieSchema requestedSchema;                // projected schema (required cols only)
      private Option<InternalSchema> internalSchemaOpt = Option.empty(); // schema evolution
      private HoodieTableMetaClient hoodieTableMetaClient;
      private TypedProperties props;                       // merged hoodie + spark configs
      private Option<HoodieBaseFile> baseFileOption;       // parquet/orc base file (can be absent for log-only)
      private Stream<HoodieLogFile> logFiles;              // log files in the file slice (MOR delta logs)
      private String partitionPath;
      private long start = 0;                              // byte offset into base file (for splitting)
      private long length = Long.MAX_VALUE;                // byte length to read from base file
      private Iterator<HoodieRecord> recordIterator;       // alternative: pre-built record stream
      private boolean shouldUseRecordPosition = false;     // use parquet row-index for faster merge
      private boolean allowInflightInstants = false;
      private boolean emitDelete;                          // whether to emit delete records
      private boolean sortOutput = false;
      private Option<BaseFileUpdateCallback<T>> fileGroupUpdateCallback = Option.empty();
      private FileGroupRecordBufferLoader<T> recordBufferLoader; // how log records are loaded into buffer
  }

  The InputSplit wraps: baseFileOption + logFiles (or recordIterator) + partitionPath + start + length.


  val reader = HoodieFileGroupReader.newBuilder()
      .withReaderContext(readerContext)          // SparkFileFormatInternalRowReaderContext
      .withHoodieTableMetaClient(metaClient)    // built on driver, broadcast implicitly
      .withLatestCommitTime(queryTimestamp)     // snapshot commit time
      .withFileSlice(fileSlice)                 // baseFile + logFiles + partitionPath
      .withDataSchema(dataSchema)               // full table avro schema
      .withRequestedSchema(requestedSchema)     // pruned projection schema
      .withInternalSchema(internalSchemaOpt)    // schema evolution (may be empty)
      .withProps(props)                         // table config props + spark options + memory config
      .withStart(file.start)                    // PartitionedFile split offset
      .withLength(baseFileLength)               // base file byte length
      .withShouldUseRecordPosition(shouldUseRecordPosition)
      .build()

